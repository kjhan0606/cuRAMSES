This is the Ponomarenko test performed in Teyssier, Fromang and Dormy (2006).
Originally levelmax=8 and tout=200

&RUN_PARAMS
hydro=.true.
nremap=1
ncontrol=1
nsubcycle=4*1,2
/

&AMR_PARAMS
levelmin=5
levelmax=7
ngridmax=2000000
nexpand=1
boxlen=8.055
/

&INIT_PARAMS
condinit_kind="ponomarenko"
nregion=2
/

&OUTPUT_PARAMS
noutput=1
tout=10
!delta_tout=2.
/

&HYDRO_PARAMS
gamma=1.6666667
courant_factor=0.8
slope_type=2
riemann='upwind'
riemann2d='upwind'
scheme='induction'
eta_mag=0.0025
/

&REFINE_PARAMS
err_grad_u=0.1
interpol_var=0
interpol_type=2
/
