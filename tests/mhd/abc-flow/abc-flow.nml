!This is the ABC-flow test performed in Teyssier, Fromang and Dormy (2006).
!Originally levelmax=8 and tout=80

&RUN_PARAMS
hydro=.true.
nremap=1
ncontrol=1
nsubcycle=4*1,2
/

&AMR_PARAMS
levelmin=5
levelmax=5
ngridmax=2000000
nexpand=1
boxlen=1
/

&INIT_PARAMS
nregion=1
region_type(1)='square'
x_center=0.5
y_center=0.5
z_center=0.5
length_x=10.0
length_y=10.0
length_z=10.0
exp_region=10.0
d_region=1.0
u_region=0.0
v_region=0.0
w_region=0.0
p_region=1.0
A_region=0.0
B_region=0.0
C_region=1.0e-3
/


&OUTPUT_PARAMS
!delta_tout=0.1
noutput=1
tout=10.0
/

&HYDRO_PARAMS
gamma=1.6666667
courant_factor=0.8
slope_type=2
riemann='upwind'
riemann2d='upwind'
scheme='induction'
eta_mag=0.001
/

&REFINE_PARAMS
err_grad_b2=0.1
interpol_var=0
interpol_type=2
/
