! Uniform density 10 H/cc, uniform T=10 initially
! one massive sink in the middle (id=6) and one in the corner
! 5 additional low mass sinks around to verify SN is done on the correct sink
! initially 2 sinks close together which merge before stellar particle is born (sink_id != isink)
! Initial dmf = initial mass
! TODO: make work on 4 cpus

&RUN_PARAMS
hydro=.true.
nrestart=0
nremap=10
poisson=.true.
rt=.true.
pic=.true.
sink=.true.
stellar=.true.
nsubcycle=1
verbose=.false.
/

&INIT_PARAMS
nregion=1
region_type(1)='square'
x_center=125
y_center=125
z_center=125
length_x=250
length_y=250
length_z=250
exp_region=10.0
d_region=1d1		   	  ! 10 hydrogen atoms per cc
p_region=3300.1987634209013
/

&AMR_PARAMS
levelmin=6
levelmax=8
ngridmax=350000
npartmax=50000
nexpand=4
boxlen=250. ! pc
/

&OUTPUT_PARAMS
noutput=1
tout=0.18
/

&HYDRO_PARAMS
gamma=1.666666667
courant_factor=0.8
riemann='hllc'
slope_type=1
pressure_fix=.true.
beta_fix=0.5
/

&COOLING_PARAMS
cooling=.false.
metal=.false.
z_ave=1.0
/

&UNITS_PARAMS
units_density = 1.66d-24 ! 1 H/cc
units_time    = 3.004683525921981d15 !95.21470899675022 Myr
units_length  = 3.08567758128200d18 ! 1 pc
/

&REFINE_PARAMS
jeans_refine=8
interpol_type=0
interpol_var=1
sink_refine=.true.
/

&POISSON_PARAMS
gravity_type=0
/

&SINK_PARAMS
nlevelmax_sink=7
create_sinks=.false.
nsinkmax=10
mass_sink_seed=1 ! in M_sun
accretion_scheme='bondi'
merging_timescale=1d50
n_sink=1d2 ! ramses doens't like it if you don't set this
/

&STELLAR_PARAMS
sn_feedback_sink=.false.
nstellarmax=10
stellar_msink_th=300. ! threshold for stellar obj creation
mstellarini=50,50,50,50,50,50
! IMF
imf_index=-2.35
imf_low=8
imf_high=120
! HII lifetime
hii_t=1000.0 ! Myr
/

&RT_PARAMS
rt_sink=.true.
X=0.76d0
Y=0.24d0
rt_output_coolstats=.true.
rt_flux_scheme='glf'
rt_smooth=.true.
rt_courant_factor=0.8
rt_c_fraction=1d-6
rt_otsa=.false.
/

&RT_GROUPS
group_csn(1,:)= 3.8808E-18, 7.6280E-22, 0.0000
group_cse(1,:)= 3.6627E-18, 1.1054E-21, 0.0000
group_csn(2,:)= 8.9878E-19, 6.1154E-18, 0.0000
group_cse(2,:)= 8.7025E-19, 5.9879E-18, 0.0000
group_csn(3,:)= 1.0528E-19, 1.5058E-18, 1.3239E-18
group_cse(3,:)= 1.0448E-19, 1.4969E-18, 1.3173E-18
group_egy     = 16.970, 28.161, 57.638
spec2group    = 1, 2, 3
/

&MOVIE_PARAMS
movie=.true.
imov=1
imovout=2
tstartmov=0.
tendmov=0.18
nw_frame=128
nh_frame=128
levelmax_frame=7
proj_axis='z'
xcentre_frame= 125.,0.,0.,0.
ycentre_frame= 125.,0.,0.,0.
zcentre_frame= 125.,0.,0.,0.
deltax_frame= 250, 0.
deltay_frame= 250, 0.
deltaz_frame= 250, 0.
movie_vars_txt = 'temp', 'xHII', 'Fp3'
perspective_camera = .false.
shader_frame =       'cube'
dtheta_camera=       100       ! The camera rotates around the box with time
phi_camera=          80.       ! The camera is at a fixed latitudal angle
focal_camera=        250.
dist_camera=         250.
method_frame='max'
/
