&RUN_PARAMS
cosmo=.true.
pic=.true.
poisson=.true.
hydro=.true.
nremap=0
nsubcycle=1,1,30*2
verbose=.false.
/

&OUTPUT_PARAMS
noutput=1
aout=4.66e-02
/

&INIT_PARAMS
filetype='grafic'
initfile(1)='cosmo_128'
/

&AMR_PARAMS
levelmin=7
levelmax=12
ngridtot=1000000
nparttot=6000000
nexpand=1
/

&REFINE_PARAMS
m_refine=30*8.,
interpol_var=1
interpol_type=0
/

&POISSON_PARAMS
epsilon=1d-4
/

&HYDRO_PARAMS
gamma=1.666667
courant_factor=0.8
scheme='muscl'
slope_type=1
riemann='hllc'
pressure_fix=.true.
beta_fix=0.5
/


&SF_PARAMS
sf_model=0
eps_star=0.3
del_star=2.e2
n_star=2.4e-9
T2_star=1.e-20
g_star=1.6666667
randomize_sf=.false.
/

&STELLAR_PARAMS
iseed = 0
/

&FEEDBACK_PARAMS
f_w=0.5
f_ek=0.5
eta_sn=0.1 ! set to 0 to test without SN FB
yield=0.05
rbubble=200.
/

&COOLING_PARAMS
J21=0.1
z_reion=5
cooling=.true.
metal=.true.
/
