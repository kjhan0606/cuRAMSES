&RUN_PARAMS
cosmo=.true.
pic=.true.
poisson=.true.
hydro=.false.
nremap=0
nsubcycle=1,1,30*2
clumpfind=.true.
/

&OUTPUT_PARAMS
noutput=1
aout=1.355E-01
/

&INIT_PARAMS
filetype='grafic'
initfile(1)='cosmo_128'
/

&AMR_PARAMS
levelmin=7
levelmax=7
ngridtot=500000
nparttot=3000000
nexpand=1
/

&REFINE_PARAMS
m_refine=30*8.,
interpol_var=1
interpol_type=0
/

&POISSON_PARAMS
epsilon=1d-4
/


&CLUMPFIND_PARAMS
relevance_threshold=3
density_threshold=80
saddle_threshold=100
mass_threshold=10
ivar_clump=0
clinfo=.true.
/
