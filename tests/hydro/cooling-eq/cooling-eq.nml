This is the RAMSES parameter file for the equilibrium cooling module test.
It is a 2D run with 2*2 (i.e. four) cells, hydro-static, and with a z=0 HM UV backgound,
so there is no flow between the cells and the only evolution is therefore the radiative
cooling (and heating due to the UVB) in each cell.

&RUN_PARAMS
hydro=.true.
static_gas=.true.
ncontrol=50000
/

&AMR_PARAMS
levelmin=1
levelmax=1
ngridmax=100
boxlen=1
/

&HYDRO_PARAMS
gamma=1.666667
courant_factor=0.8
/

&INIT_PARAMS
nregion=4
region_type='square'
x_center=0.25, 0.75, 0.25, 0.75
y_center=0.25, 0.25, 0.75, 0.75
length_x=0.5, 0.5, 0.5, 0.5
length_y=0.5, 0.5, 0.5, 0.5
exp_region=10
d_region=3d-2, 3d0, 3d-2, 3d0      ! cm-3
p_region=  0.0260938, 2.6094,  2609.38, 260938.5    ! 1e2, 1e2, 1e7, 1e7 K
/

&OUTPUT_PARAMS
! 100 outputs, evenly log-spaced, ending at 500 myrs
tout = 0.0003, 0.00034671147, 0.00040069615, 0.00046308651, 0.00053519135, 0.00061852327, 0.00071483037, 0.00082613297, 0.00095476593, 0.0011034277, 0.0012752368, 0.0014737974, 0.0017032749, 0.0019684831, 0.0022749856, 0.002629212, 0.0030385932, 0.0035117171, 0.0040585087, 0.0046904384, 0.0054207627, 0.0062648021, 0.0072402625, 0.0083676069, 0.0096704843, 0.011176226, 0.012916419, 0.014927569, 0.017251865, 0.019938065, 0.02304252, 0.026630353, 0.03077683, 0.035568933, 0.04110719, 0.047507782, 0.054904976, 0.063453951, 0.073334042, 0.084752512, 0.097948894, 0.11320002, 0.13082582, 0.15119604, 0.174738, 0.20194557, 0.23338948, 0.26972937, 0.31172756, 0.36026507, 0.4163601, 0.48118941, 0.55611297, 0.64270249, 0.74277442, 0.85842804, 0.99208949, 1.1465627, 1.3250881, 1.5314109, 1.769859, 2.0454348, 2.363919, 2.7319928, 3.1573775, 3.6489966, 4.2171633, 4.8737963, 5.6326704, 6.5097048, 7.5232977, 8.6947121, 10.048521, 11.613126, 13.421346, 15.511116, 17.926272, 20.717481, 23.943294, 27.671383, 31.979953, 36.959389, 42.714147, 49.364949, 57.051314, 65.934483, 76.200806, 88.065645, 101.7779, 117.62522, 135.94004, 157.10657, 181.56883, 209.83999, 242.51311, 280.27359, 323.91356, 374.34849, 432.63639, 500
/

&UNITS_PARAMS
units_density=2.18492d-24 ! 1 H/cc
units_time=3.156d13       ! 1 Myr
units_length=3.0857d18    ! 1 pc
/

&COOLING_PARAMS
cooling=.true.
z_ave=0.1
haardt_madau=.true.
/
