
&RUN_PARAMS
hydro=.true.
ncontrol=1
nrestart=0
nremap=0
nsubcycle=10*2
verbose=.false.
/

&AMR_PARAMS
levelmin=4
levelmax=7
ngridtot=40000
nexpand=0
boxlen=0.5
/

&INIT_PARAMS
nregion=2
region_type(1)='square'
region_type(2)='point'
x_center=0.5,0.0
y_center=0.5,0.0
z_center=0.5,0.0
length_x=10.0,1.0
length_y=10.0,1.0
length_z=10.0,1.0
exp_region=10.0,10.0
d_region=1.0,0.0
u_region=0.0,0.0
v_region=0.0,0.0
w_region=0.0,0.0
p_region=1e-5,0.4
/

&OUTPUT_PARAMS
noutput=1
tout=9.91d-3
/

&HYDRO_PARAMS
gamma=1.4
courant_factor=0.8
scheme='muscl'
slope_type=8
riemann='hll'
/

&REFINE_PARAMS
interpol_var=2
interpol_type=1
err_grad_p=0.1
r_refine=0.125,0.0625,0.03125
x_refine=0.0625,0.0625
y_refine=0.0625,0.0625
z_refine=0.0625,0.0625
exp_refine=10,10.,10.
/
